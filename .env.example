MINIMAX_API_KEY=replace_me
MINIMAX_TTS_ENDPOINT=https://api.minimaxi.com/v1/t2a_async_v2
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE_ID=Chinese (Mandarin)_Soft_Girl
MINIMAX_TTS_EMOTION=calm
MINIMAX_TTS_LANGUAGE_BOOST=Chinese
MINIMAX_TTS_SPEED=1.2
MINIMAX_TTS_VOLUME=1.0
MINIMAX_TTS_PITCH=0

# Optional multi-provider TTS credentials
DASHSCOPE_API_KEY=replace_me
TENCENTCLOUD_SECRET_ID=replace_me
TENCENTCLOUD_SECRET_KEY=replace_me
VOLCENGINE_TTS_TOKEN=replace_me
VOLCENGINE_TTS_APPID=replace_me

# The local launcher binds to loopback by default. To expose it to a LAN,
# choose a non-loopback host and set a strong access token.
PPT_STUDIO_HOST=127.0.0.1
PPT_STUDIO_PORT=8000
# PPT_STUDIO_ACCESS_TOKEN=replace_with_a_long_random_token

# Optional upload/import safety limits
PPT_STUDIO_MAX_IMAGE_UPLOAD_BYTES=20971520
PPT_STUDIO_MAX_IMAGE_PIXELS=50000000
PPT_STUDIO_MAX_CONFIG_IMPORT_BYTES=26214400
