# Runtime projects
runs/*
!runs/.gitkeep

# User-facing exports
outputs/*
!outputs/.gitkeep

# Generated media and assets
*.mp4
*.mov
*.m4v
*.wav
*.mp3
*.aac
*.flac
*.srt
*.vtt
*.png
*.jpg
*.jpeg
*.webp
!references/style_reference/
!references/style_reference/*.png
!references/style_reference/*.jpg
!references/style_reference/*.jpeg
!references/style_reference/*.webp

# Local caches and builds
.cache/
.tmp/
node_modules/
dist/
build/
.remotion/
scripts/remotion/public/runtime/

# Python
__pycache__/
*.pyc
.venv/
venv/
.coverage
.coverage.*
htmlcov/

# Secrets
.env
.env.*
!.env.example

# Sensitive local settings exports (never commit)
ppt-studio-global-settings-sensitive*.json
*-sensitive-*.json

*.log
*.pid
scratch/
work/
data/
