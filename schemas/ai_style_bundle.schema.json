{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/ai_style_bundle.schema.json",
  "title": "AI Image Style Template Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "description",
    "style_data",
    "template_paste_words",
    "example_paste_words",
    "template_image_prompt",
    "example_image_prompt",
    "negative_prompt"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 60
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "style_data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brand": {
          "type": "object"
        },
        "canvas": {
          "type": "object"
        },
        "colors": {
          "type": "object"
        },
        "layout": {
          "type": "object"
        },
        "visual_assets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "image_style": {"type": "string"},
            "diagram_style": {"type": "string"},
            "required_background": {"type": "string"},
            "reveal_friendly_layout": {
              "type": "array",
              "items": {"type": "string"}
            },
            "avoid": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "template_paste_words": {
      "$ref": "#/$defs/pasteWords"
    },
    "example_paste_words": {
      "$ref": "#/$defs/pasteWords"
    },
    "template_image_prompt": {
      "type": "string",
      "minLength": 1
    },
    "example_image_prompt": {
      "type": "string",
      "minLength": 1
    },
    "negative_prompt": {
      "type": "string"
    }
  },
  "$defs": {
    "pasteWords": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "subtitle", "groups"],
      "properties": {
        "title": {"type": "string", "minLength": 1, "maxLength": 40},
        "subtitle": {"type": "string", "minLength": 1, "maxLength": 60},
        "groups": {
          "type": "array",
          "minItems": 4,
          "maxItems": 8,
          "items": {"type": "string", "minLength": 1, "maxLength": 20}
        },
        "badges": {
          "type": "array",
          "maxItems": 8,
          "items": {"type": "string", "minLength": 1, "maxLength": 12}
        }
      }
    }
  }
}
