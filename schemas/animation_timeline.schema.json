{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnimationTimeline",
  "type": "object",
  "required": ["slide_id", "duration_sec", "events"],
  "properties": {
    "slide_id": {"type": "string"},
    "duration_sec": {"type": "number"},
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "target", "action", "at", "duration"],
        "properties": {
          "id": {"type": "string"},
          "target": {"type": "string"},
          "action": {
            "type": "string",
            "enum": [
              "fade_in",
              "fade_up",
              "soft_zoom_in",
              "slide_in_left",
              "line_draw",
              "highlight",
              "count_up"
            ]
          },
          "at": {"type": "number", "minimum": 0},
          "duration": {"type": "number", "minimum": 0},
          "linked_segment_id": {"type": "string"},
          "easing": {"type": "string"},
          "params": {"type": "object"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
