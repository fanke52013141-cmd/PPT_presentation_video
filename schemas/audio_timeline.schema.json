{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AudioTimeline",
  "type": "object",
  "required": ["slide_id", "audio_file", "segments"],
  "properties": {
    "slide_id": {"type": "string"},
    "audio_file": {"type": "string"},
    "duration_sec": {"type": "number"},
    "timing_source": {"type": "string", "enum": ["minimax", "estimated", "manual"]},
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "start", "end", "text"],
        "properties": {
          "id": {"type": "string"},
          "start": {"type": "number"},
          "end": {"type": "number"},
          "text": {"type": "string"},
          "max_cjk_chars": {"type": "number"},
          "max_lines": {"type": "number"}
        }
      }
    }
  },
  "additionalProperties": true
}