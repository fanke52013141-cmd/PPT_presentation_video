{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Image Gen Macro Layer Manifest",
  "type": "object",
  "required": ["version", "canvas", "slides"],
  "properties": {
    "version": {
      "type": "string",
      "const": "image_gen_macro_layers_v1"
    },
    "canvas": {
      "type": "object",
      "required": ["width", "height", "background"],
      "properties": {
        "width": {"type": "number", "exclusiveMinimum": 0},
        "height": {"type": "number", "exclusiveMinimum": 0},
        "background": {"type": "string"}
      },
      "additionalProperties": true
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slide_id", "slide_dir", "layers"],
        "properties": {
          "slide_id": {"type": "string", "minLength": 1},
          "slide_dir": {"type": "string", "minLength": 1},
          "background_source": {"type": "string"},
          "canvas": {
            "type": "object",
            "properties": {
              "width": {"type": "number", "exclusiveMinimum": 0},
              "height": {"type": "number", "exclusiveMinimum": 0},
              "background": {"type": "string"}
            },
            "additionalProperties": true
          },
          "white_key_alpha": {
            "type": "object",
            "additionalProperties": true
          },
          "layers": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": {
              "type": "object",
              "required": ["id", "role", "source", "box"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "role": {
                  "type": "string",
                  "enum": [
                    "title",
                    "subtitle",
                    "content_body",
                    "diagram",
                    "annotation",
                    "summary",
                    "decoration"
                  ]
                },
                "source": {"type": "string", "minLength": 1},
                "asset": {"type": "string"},
                "box": {
                  "type": "object",
                  "required": ["x", "y", "w", "h"],
                  "properties": {
                    "x": {"type": "number", "minimum": 0},
                    "y": {"type": "number", "minimum": 0},
                    "w": {"type": "number", "exclusiveMinimum": 0},
                    "h": {"type": "number", "exclusiveMinimum": 0}
                  },
                  "additionalProperties": false
                },
                "z_index": {"type": "number"},
                "animation": {
                  "type": "string",
                  "enum": ["static", "fade_in", "fade_up", "soft_zoom_in", "slide_in_left", "highlight"]
                },
                "entry_animation": {
                  "type": "string",
                  "enum": ["static", "fade_in", "fade_up", "soft_zoom_in", "slide_in_left"]
                },
                "reveal_at": {"type": "number", "minimum": 0},
                "reveal_duration": {"type": "number", "exclusiveMinimum": 0},
                "highlight_at": {"type": "number", "minimum": 0},
                "text_summary": {"type": "string"},
                "narration_cue": {"type": "string"},
                "key_white": {"type": "boolean"},
                "white_key_alpha": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
