{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scene",
  "type": "object",
  "required": ["slide_id", "canvas", "elements"],
  "properties": {
    "slide_id": {"type": "string"},
    "source_visual_draft": {"type": "string"},
    "canvas": {
      "type": "object",
      "required": ["width", "height", "background"],
      "properties": {
        "width": {"type": "number"},
        "height": {"type": "number"},
        "background": {"type": "string"}
      }
    },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "box", "z_index", "region", "semantic_role"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string", "enum": ["text", "image", "shape", "line", "group"]},
          "text": {"type": "string"},
          "asset": {"type": "string"},
          "style_token": {"type": "string"},
          "animation_role": {"type": "string"},
          "region": {"type": "string", "enum": ["title_block", "content"]},
          "semantic_role": {
            "type": "string",
            "enum": [
              "main_title",
              "subtitle",
              "content_point",
              "content_text",
              "content_visual",
              "content_diagram",
              "content_shape",
              "content_line",
              "content_highlight",
              "brand_marker",
              "subtitle_underline",
              "content_frame",
              "content_arrow",
              "content_token_block",
              "content_icon",
              "keyword_underline",
              "keyword_circle",
              "summary_bar",
              "summary_icon",
              "capsule_label"
            ]
          },
          "content_index": {"type": "number"},
          "box": {"type": "object","required": ["x","y","w","h"],"properties": {"x": {"type": "number"},"y": {"type": "number"},"w": {"type": "number"},"h": {"type": "number"}}},
          "z_index": {"type": "number"}
        }
      }
    }
  },
  "additionalProperties": true
}