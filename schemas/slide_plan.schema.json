{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SlidePlan",
  "type": "object",
  "required": ["topic", "slides"],
  "properties": {
    "topic": {
      "type": "object",
      "required": ["topic_id", "topic_name", "topic_summary"],
      "properties": {
        "topic_id": {"type": "string"},
        "topic_name": {"type": "string"},
        "topic_summary": {"type": "string"}
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "slide_id",
          "slide_purpose",
          "main_title",
          "subtitle",
          "core_message",
          "content",
          "narration"
        ],
        "properties": {
          "slide_id": {"type": "string"},
          "slide_purpose": {"type": "string"},
          "main_title": {"type": "string"},
          "subtitle": {"type": "string"},
          "core_message": {"type": "string"},
          "content": {
            "type": "object",
            "required": ["content_type", "layout_intent", "items"],
            "properties": {
              "content_type": {"type": "string"},
              "layout_intent": {"type": "string"},
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {"type": "string"},
                    "label": {"type": "string"},
                    "side": {"type": "string"},
                    "text": {"type": "string"}
                  }
                }
              }
            }
          },
          "narration": {"type": "string"}
        }
      }
    }
  },
  "additionalProperties": true
}