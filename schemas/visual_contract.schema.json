{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VisualContract",
  "type": "object",
  "required": ["version", "slides"],
  "properties": {
    "version": {"type": "string", "const": "visual_contract_v1"},
    "presentation_policy": {
      "type": "object",
      "required": ["subtitle_policy"],
      "properties": {
        "subtitle_policy": {
          "type": "string",
          "enum": ["all_slides_have_subtitle", "no_slides_have_subtitle"]
        },
        "subtitle_decided_by": {"type": "string"},
        "subtitle_rationale": {"type": "string"},
        "default_visual_group_count": {"type": "string"},
        "layout_diversity": {"type": "string"}
      },
      "additionalProperties": true
    },
    "topic": {
      "type": "object",
      "properties": {
        "topic_id": {"type": "string"},
        "topic_name": {"type": "string"},
        "topic_summary": {"type": "string"}
      },
      "additionalProperties": true
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slide_id", "main_title", "visual_groups", "narration_beats"],
        "properties": {
          "slide_id": {"type": "string", "minLength": 1},
          "slide_purpose": {"type": "string"},
          "main_title": {"type": "string", "minLength": 1},
          "subtitle": {"type": "string"},
          "core_message": {"type": "string"},
          "layout_type": {"type": "string"},
          "visual_metaphor": {"type": "string"},
          "composition": {
            "type": "object",
            "properties": {
              "primary_focus": {"type": "string"},
              "reading_order": {"type": "string"},
              "hierarchy": {"type": "array", "items": {"type": "string"}},
              "group_count": {"type": ["number", "string"]}
            },
            "additionalProperties": true
          },
          "visual_groups": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "role", "visible_text", "visual_anchor", "narration_function"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "role": {
                  "type": "string",
                  "description": "Configurable visual role. Built-ins include title/subtitle/content_body/diagram/annotation/summary/decoration/quote/data_point/process_step/callout; custom roles are allowed."
                },
                "visible_text": {"type": "string", "minLength": 1},
                "visual_anchor": {"type": "string", "minLength": 1},
                "narration_function": {"type": "string", "minLength": 1},
                "reveal_order": {"type": "number", "minimum": 0},
                "layout_hint": {"type": "string"}
              },
              "additionalProperties": true
            }
          },
          "narration_beats": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "group_id", "visible_anchor", "spoken_intent"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "group_id": {"type": "string", "minLength": 1},
                "visible_anchor": {"type": "string", "minLength": 1},
                "spoken_intent": {"type": "string", "minLength": 1},
                "spoken_text": {"type": "string"},
                "linked_segment_id": {"type": "string"},
                "time_hint": {"type": "string"}
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
