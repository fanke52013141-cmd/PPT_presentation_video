{
  "version": "master_split_v1",
  "canvas": {
    "width": 1920,
    "height": 1080,
    "background": "#FFFDF7"
  },
  "slides": [
    {
      "slide_id": "slide_001",
      "slide_dir": "runs/<run_id>/slides/slide_001",
      "master": "visual_draft.png",
      "background_mode": "paper_texture",
      "default_duration_sec": 12,
      "layout_constraints": {
        "min_macro_layer_gap_px": 48,
        "overlap_tolerance_px": 4,
        "max_visible_overlap_px": 96,
        "visible_overlap_alpha_threshold": 160,
        "subtitle_safe_y": 930,
        "min_content_layers": 4,
        "max_content_layers": 8
      },
      "narration_beats": [
        {
          "id": "beat_01",
          "start": 0,
          "end": 2.5,
          "text": "First spoken point that introduces the title or main visual.",
          "visual_group": "title_group",
          "animation": "slide_in_left"
        }
      ],
      "layers": [
        {
          "id": "title_group",
          "role": "title",
          "box": {"x": 60, "y": 40, "w": 720, "h": 180},
          "z_index": 20,
          "animation": "slide_in_left",
          "narration_beat_id": "beat_01",
          "text_summary": "Main title and subtitle marker.",
          "narration_cue": "The opening sentence introduces the topic."
        },
        {
          "id": "diagram_group",
          "role": "diagram",
          "box": {"x": 560, "y": 250, "w": 760, "h": 540},
          "z_index": 30,
          "animation": "soft_zoom_in",
          "narration_beat_id": "beat_02",
          "text_summary": "Main explanatory diagram.",
          "narration_cue": "The narration explains the central analogy or process."
        },
        {
          "id": "summary_group",
          "role": "summary",
          "box": {"x": 1260, "y": 740, "w": 560, "h": 150},
          "z_index": 40,
          "animation": "highlight",
          "narration_beat_id": "beat_05",
          "text_summary": "Final takeaway.",
          "narration_cue": "The closing beat summarizes the page."
        }
      ]
    }
  ]
}
